*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- Datos pesados (NUNCA subir microdatos a GitHub) ---
data/raw/
data/usuario/
data/processed/
indec_auto/data/
indec_auto/outputs/
indec_auto/.mpl/
*.xlsx
*.xls
*.csv
*.dbf
*.txt
